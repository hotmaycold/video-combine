{
  "name": "video-combine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "tsx watch apps/api/src/main.ts",
    "dev:web": "npm run dev -w @video-combine/web",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && npm run build -w @video-combine/web"
  },
  "devDependencies": {
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@types/node": "^22.15.17",
    "@vitejs/plugin-react": "^4.4.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.1.3"
  }
}
